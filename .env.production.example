# ============================================================
# NexCal — Production Environment Variables
# ============================================================
# Salin file ini: cp .env.production.example .env
# Lalu isi nilainya sesuai environment server Anda.
# ============================================================

# ===========================================
# DATABASE (WAJIB)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Jika pakai Docker Compose, gunakan "db" sebagai HOST.
# Jika pakai Supabase/Neon, tempelkan connection string dari dashboard.
DATABASE_URL="postgresql://nexcal_admin:GANTI_PASSWORD_KUAT@db:5432/nexcal_db?schema=public"

# PostgreSQL credentials (hanya untuk Docker Compose)
POSTGRES_USER="nexcal_admin"
POSTGRES_PASSWORD="GANTI_PASSWORD_KUAT"
POSTGRES_DB="nexcal_db"

# ===========================================
# AUTH.JS / NextAuth v5 (WAJIB)
# ===========================================
# Generate secret: openssl rand -base64 32
AUTH_SECRET="GANTI_DENGAN_RANDOM_SECRET_32_KARAKTER"

# Harus "true" jika di belakang reverse proxy (Nginx, Caddy, Cloudflare)
AUTH_TRUST_HOST=true

# ===========================================
# APP CONFIG (WAJIB)
# ===========================================
# URL publik aplikasi Anda (tanpa trailing slash)
NEXT_PUBLIC_APP_URL="https://booking.domain-anda.com"

# Nama brand yang muncul di UI
NEXT_PUBLIC_APP_NAME="NexCal"

# ===========================================
# SEED (OPSIONAL)
# ===========================================
# Password untuk akun admin default (saat pertama kali seed)
# Segera ganti di UI setelah deploy!
SEED_PASSWORD="GANTI_PASSWORD_ADMIN"

# ===========================================
# PORT (OPSIONAL)
# ===========================================
# Port yang diekspos oleh Docker ke host. Default: 3000
APP_PORT=3000
