# ============================================================
# NexCal — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------
# For local development (with docker-compose.yml):
# Replace <DB_USER>, <DB_PASSWORD>, and <DB_NAME> with your own values.
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5434/<DB_NAME>?schema=public"

# For Docker production (docker-compose.prod.yml handles this
# automatically via service name, but you can override):
# DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@db:5432/<DB_NAME>?schema=public"

# Docker Compose overrides (used in docker-compose.prod.yml):
POSTGRES_USER="<DB_USER>"
POSTGRES_PASSWORD="<DB_PASSWORD>"
POSTGRES_DB="<DB_NAME>"

# -----------------------------------------------------------
# AUTH.JS (NextAuth v5)
# -----------------------------------------------------------
# REQUIRED — Generate with: openssl rand -base64 32
AUTH_SECRET="<GENERATE_WITH_openssl_rand_-base64_32>"

# Trust host header (set true behind reverse proxy)
AUTH_TRUST_HOST=true

# -----------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME="NexCal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Port mapping for Docker production (default: 3000)
APP_PORT=3000

# -----------------------------------------------------------
# SEED PASSWORD (Development only)
# -----------------------------------------------------------
# Password used by `npx prisma db seed` for demo users.
# Default: changeme123
SEED_PASSWORD="<YOUR_LOCAL_SEED_PASSWORD>"

# -----------------------------------------------------------
# WHATSAPP NOTIFICATIONS (MultiWA — Optional)
# -----------------------------------------------------------
# Connect to your MultiWA instance for automatic WhatsApp
# booking notifications. Leave blank to disable.
# Get MultiWA: https://github.com/ribato22/MultiWA
MULTIWA_API_URL=""
MULTIWA_API_KEY=""
MULTIWA_SESSION_ID=""

# -----------------------------------------------------------
# GOOGLE CALENDAR SYNC (Optional)
# -----------------------------------------------------------
# Enable 1-way sync: confirmed bookings → Google Calendar.
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/calendar.events
# Authorized redirect URI: {APP_URL}/api/gcal/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------
# PAYMENT GATEWAY (Optional — Plugin-based)
# -----------------------------------------------------------
# Atur gateway default. Kosongkan untuk menonaktifkan fitur pembayaran.
# Nilai yang didukung: MIDTRANS (segera: XENDIT, STRIPE)
DEFAULT_PAYMENT_GATEWAY=""

# Midtrans Plugin — https://dashboard.midtrans.com
# Sandbox keys: https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
