# ============================================================
# NexCal — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------
# For local development (with docker-compose.yml):
DATABASE_URL="postgresql://booking_admin:REDACTED_DB_PASSWORD@localhost:5434/booking_db?schema=public"

# For Docker production (docker-compose.prod.yml handles this
# automatically via service name, but you can override):
# DATABASE_URL="postgresql://nexcal_admin:REDACTED_DB_PASSWORD@db:5432/nexcal_db?schema=public"

# Docker Compose overrides (used in docker-compose.prod.yml):
POSTGRES_USER="nexcal_admin"
POSTGRES_PASSWORD="REDACTED_DB_PASSWORD"
POSTGRES_DB="nexcal_db"

# -----------------------------------------------------------
# AUTH.JS (NextAuth v5)
# -----------------------------------------------------------
# REQUIRED — Generate with: openssl rand -base64 32
AUTH_SECRET="ganti-dengan-secret-random-yang-aman-minimal-32-karakter"

# Trust host header (set true behind reverse proxy)
AUTH_TRUST_HOST=true

# -----------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------
NEXT_PUBLIC_APP_NAME="NexCal"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Port mapping for Docker production (default: 3000)
APP_PORT=3000

# -----------------------------------------------------------
# WHATSAPP NOTIFICATIONS (MultiWA — Optional)
# -----------------------------------------------------------
# Connect to your MultiWA instance for automatic WhatsApp
# booking notifications. Leave blank to disable.
# Get MultiWA: https://github.com/ribato22/MultiWA
MULTIWA_API_URL=""
MULTIWA_API_KEY=""
MULTIWA_SESSION_ID=""
